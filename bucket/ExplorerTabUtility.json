{
    "version": "2.5.0",
    "description": "🚀 Supercharge Windows 11's File Explorer: Auto-convert windows to tabs, duplicate tabs, reopen closed ones, and more!",
    "homepage": "https://github.com/w4po/ExplorerTabUtility",
    "license": "MIT",
    "notes": "1. Hash code not supplied; 2. Dotnet 9.0 runtime required; 3. config maybe not work, you should backup manually",
    "pre_install": [
        "Get-ChildItem \"$dir\" -Directory | ForEach-Object { Move-Item -Path \"$($_.FullName)\\*\" -Destination \"$dir\\\" -Force; Remove-Item -Path \"$($_.FullName)\" -Recurse }",
        "if (!(Test-Path \"$persist_dir\\ExplorerTabUtility.runtimeconfig.json\")) { New-Item -ItemType File -Path \"$dir\\ExplorerTabUtility.runtimeconfig.json\" -Force | Out-Null }"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/w4po/ExplorerTabUtility/releases/download/v2.5.0/ExplorerTabUtility_v2.5.0_x64_Net9.0_FrameworkDependent.zip"
        },
        "32bit": {
            "url": "https://github.com/w4po/ExplorerTabUtility/releases/download/v2.5.0/ExplorerTabUtility_v2.5.0_x86_Net9.0_FrameworkDependent.zip"
        },
        "arm64": {
            "url": "https://github.com/w4po/ExplorerTabUtility/releases/download/v2.5.0/ExplorerTabUtility_v2.5.0_arm64_Net9.0_FrameworkDependent.zip"
        }
    },
    "bin": "ExplorerTabUtility.exe",
    "shortcuts": [["ExplorerTabUtility.exe", "ExplorerTabUtility"]],
    "persist": "ExplorerTabUtility.runtimeconfig.json",
    "checkver": {
        "github": "https://github.com/w4po/ExplorerTabUtility"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/w4po/ExplorerTabUtility/releases/download/v$version/ExplorerTabUtility_v$version_x64_Net9.0_FrameworkDependent.zip"
            },
            "32bit": {
                "url": "https://github.com/w4po/ExplorerTabUtility/releases/download/v$version/ExplorerTabUtility_v$version_x86_Net9.0_FrameworkDependent.zip"
            },
            "arm64": {
                "url": "https://github.com/w4po/ExplorerTabUtility/releases/download/v$version/ExplorerTabUtility_v$version_arm64_Net9.0_FrameworkDependent.zip"
            }
        }
    }
}
